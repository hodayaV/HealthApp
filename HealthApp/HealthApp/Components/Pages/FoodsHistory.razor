	string Water()
	{
		int numOfGlass = FTService.NumGlassBeforNumOfDays(BeforeNumDay);
		return "you drank " + numOfGlass + " glass of water.";
	}
	string StringForDay(int day)
	{
		if (day == -1) { return "click for chose"; }
		if (day == 0) { return "today"; }
		if (day == 1) { return "yesterday"; }
		else { return day + "  days ago"; }
	}
	string FoodTodayString(FoodToday food) => FService.FoodTodayString(food);
	async void ShowDetails(FoodToday food)
	{
		await Application.Current.MainPage.DisplayAlert(FoodTitleForAmount(food), FoodDetailsString(food), "OK");
	}
	string FoodDetailsString(FoodToday food) => FService.FoodDetailsString(food);
	string FoodTitleForAmount(FoodToday food) => FService.FoodTitleForAmount(food);

